; engine-strict=true
; ignore-scripts=true
; audit=true
; min-release-age=1
;
; save-exact=true
; audit-level=high
; strict-peer-deps=true
; allow-git=root

# --- セキュリティ設定 ---
# 任意実行スクリプトを禁止（プロジェクト側で設定済みならOK）
ignore-scripts=true
# 脆弱性チェックを厳格に
audit=true
audit-level=high

# --- 依存関係の健全性 ---
# 依存解決を厳格にする（依存関係の不整合を防ぐ）
strict-peer-deps=true
# バージョンを固定して再現性を高める
save-exact=true
save-prefix=""

# --- 互換性 ---
# 指定したNodeバージョン以外でのinstallを禁止
engine-strict=true
